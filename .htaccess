# FamilyPlan is designed to run with index.php in the project root.
# Keep application internals and local secrets unreachable when using Apache.
Options -Indexes

<FilesMatch "^(config\.local\.php|config\.sample\.php|README\.md|\.gitignore|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(src|database|\.git)(/|$) - [F,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "DENY"
</IfModule>

<FilesMatch "^(index\.php|api\.php|sw\.js|manifest\.webmanifest)$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
    </IfModule>
</FilesMatch>

<FilesMatch "\.(css|js|svg)$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-cache, must-revalidate"
    </IfModule>
</FilesMatch>
