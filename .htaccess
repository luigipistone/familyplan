# FamilyPlan is designed to run with index.php in the project root.
# Keep application internals and local secrets unreachable when using Apache.
Options -Indexes

<FilesMatch "^(config\.local\.php|config\.sample\.php|README\.md|\.gitignore|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(src|database|\.git)(/|$) - [F,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "DENY"
</IfModule>
